{"actor":"","body":"[{\"ac\":1,\"text\":\"`cargo build -p heimq --release` passes.\",\"kind\":\"command\",\"verifiable\":true},{\"ac\":2,\"text\":\"A local checksum command equivalent to the workflow step works for target/release/heimq, for example `shasum -a 256 target/release/heimq` on macOS or `sha256sum target/release/heimq` on Linux.\",\"kind\":\"prose\",\"verifiable\":false},{\"ac\":3,\"text\":\"`.github/workflows/release-binaries.yml` has workflow_dispatch and tag-push triggers, uploads a binary artifact, and uploads or prints SHA256 checksums.\",\"kind\":\"prose\",\"verifiable\":false}]","created_at":"2026-06-15T22:50:21.49306474Z","kind":"ac-quality-low","source":"preclaim-ac-quality","summary":"score=0.33 threshold=0.50 verifiable=1/3"}
{"actor":"","body":"[{\"ac\":1,\"text\":\"`cargo build -p heimq --release` passes.\",\"kind\":\"command\",\"verifiable\":true},{\"ac\":2,\"text\":\"`test -x target/release/heimq \\u0026\\u0026 sh -c 'if command -v sha256sum \\u003e/dev/null 2\\u003e\\u00261; then sha256sum target/release/heimq; else shasum -a 256 target/release/heimq; fi'` prints a checksum for the built binary.\",\"kind\":\"prose\",\"verifiable\":false},{\"ac\":3,\"text\":\"`test -f .github/workflows/release-binaries.yml \\u0026\\u0026 rg -n \\\"workflow_dispatch|tags:|upload-artifact|sha256|cargo build -p heimq --release|target/release/heimq\\\" .github/workflows/release-binaries.yml` confirms dispatch/tag triggers, artifact upload, checksum handling, and the release build command are present.\",\"kind\":\"prose\",\"verifiable\":false}]","created_at":"2026-06-15T22:53:04.667149684Z","kind":"ac-quality-low","source":"preclaim-ac-quality","summary":"score=0.33 threshold=0.50 verifiable=1/3"}
